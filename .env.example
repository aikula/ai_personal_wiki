# =============================================================================
# Wiki Engine — Environment Configuration
# =============================================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Uncomment ONE provider section below and fill in your values
# 3. Set LANGUAGE to your preferred language (ru, en, etc.)
# =============================================================================

# ── Language ─────────────────────────────────────────────────────────────────
# Interface language and LLM content generation language.
# Supported: ru, en, or any language code.
LANGUAGE=ru

# ── Wiki Data Path ───────────────────────────────────────────────────────────
# Override default ./wiki-data location (optional).
# WIKI_DATA_PATH=/path/to/wiki-data

# ── Host Port ────────────────────────────────────────────────────────────────
# Override external port published by docker-compose (optional).
# APP_PORT=8000

# ── App Mode ─────────────────────────────────────────────────────────────────
# personal_local  - local personal wiki, no account system
# personal_server - personal wiki on server, optional Basic Auth
# multi_user      - server mode with accounts, workspaces, SQLite control plane
# APP_MODE=personal_local

# ── Multi-user / Server Settings ─────────────────────────────────────────────
# Only needed for APP_MODE=multi_user.
# CONTROL_DB_URL=sqlite:////wiki-data/control.db
# WIKI_WORKSPACES_ROOT=/wiki-data/workspaces
# MULTI_USER_ADMIN_EMAILS=admin@example.com
# MULTI_USER_ADMIN_EMAIL=admin@example.com
# REGISTRATION_ENABLED=true
# DEFAULT_DAILY_TOKENS=30000
# DEFAULT_WELCOME_TOKENS=200000
# DAILY_RESET_TIMEZONE=UTC

# ── Personal Server Basic Auth ───────────────────────────────────────────────
# Optional extra protection for APP_MODE=personal_server.
# WIKI_AUTH_ENABLED=true
# WIKI_AUTH_USERNAME=admin
# WIKI_AUTH_PASSWORD=change-me

# =============================================================================
# LLM PROVIDER — UNCOMMENT ONE SECTION
# =============================================================================

# ── Option 1: OpenAI (default) ───────────────────────────────────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# ── Option 2: Ollama (local) ─────────────────────────────────────────────────
# pip install ollama && ollama run qwen2.5:14b
# Recommended models: qwen2.5:14b, llama3.1:8b, gemma3:12b
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:14b
# LLM_API_KEY=ollama

# ── Option 3: vLLM (local / self-hosted) ─────────────────────────────────────
# python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-14B-Instruct
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
# LLM_API_KEY=token-abc123

# ── Option 4: OpenRouter (aggregator, many models) ───────────────────────────
# Get key at https://openrouter.ai/
# Models: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o
# LLM_API_KEY=sk-or-...

# ── Option 5: Azure OpenAI ───────────────────────────────────────────────────
# Deployment URL format includes the deployment name in the path.
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/gpt-4o
# LLM_MODEL=gpt-4o
# LLM_API_KEY=azure-key-...

# ── Option 6: Custom endpoint (vLLM, LM Studio, private LLM) ─────────────────
# Any OpenAI-compatible API server.
# LLM_BASE_URL=https://your-server.example.com/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-api-key

# ── Backwards compatibility ──────────────────────────────────────────────────
# OPENAI_API_KEY works as fallback if LLM_API_KEY is not set.
# OPENAI_API_KEY=sk-...
