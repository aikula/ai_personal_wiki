# Copy to .env and fill in values
OPENAI_API_KEY=sk-...

# Приоритетный язык UI и ответов (ru, en, etc.)
LANGUAGE=ru

# For local vLLM / Ollama:
# LLM_BASE_URL=http://localhost:11434/v1
